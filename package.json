{
  "name": "english-project-gravity",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "npx concurrently --names convex,vite --prefix-colors blue,green \"npx convex dev\" \"npx vite\"",
    "dev:frontend": "vite",
    "dev:backend": "convex dev",
    "build": "vite build && convex deploy",
    "preview": "vite preview",
    "logs": "convex logs",
    "lint": "tsc -p convex && eslint . --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "convex": "^1.33.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
